# ==========================================
# Production Environment Variables Template
# ==========================================
# COPY this file to .env and fill in your values
# NEVER commit .env to version control

# ==================== DJANGO ====================
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-this-to-a-random-secret-key-at-least-50-chars

# Your domain(s) - comma separated
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,your.server.ip.address

# ==================== DATABASE ====================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=ecommerce_prod
DB_USER=ecommerce_user
# Generate strong password: openssl rand -base64 32
DB_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD_MINIMUM_20_CHARACTERS
DB_HOST=db
DB_PORT=5432

# ==================== REDIS ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CHANNEL_DB=0
REDIS_CACHE_DB=1

# ==================== SECURITY ====================
# HTTPS Configuration
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000  # 1 year
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ==================== CORS ====================
# Your frontend domain(s) - comma separated
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://frontend.yourdomain.com

# ==================== EMAIL (Optional) ====================
# For transactional emails (password reset, order confirmation, etc.)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
# Use app-specific password, not your main password
EMAIL_HOST_PASSWORD=your-app-specific-password-here
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ==================== PAYMENT GATEWAY (Optional) ====================
# Stripe, PayPal, etc.
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# ==================== LOGGING ====================
LOG_LEVEL=INFO
# Log to file: /app/logs/django.log
LOG_FILE_PATH=/app/logs

# ==================== MONITORING (Optional) ====================
# Sentry for error tracking
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ==================== MEDIA & STATIC FILES ====================
USE_S3=False
# If using AWS S3:
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx
# AWS_STORAGE_BUCKET_NAME=xxx
# AWS_S3_REGION_NAME=us-east-1

# ==================== API RATE LIMITING ====================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600  # seconds (1 hour)

# ==================== WEBSOCKET ====================
WEBSOCKET_ACCEPT_ALL=False
WEBSOCKET_REQUIRE_AUTH=True
